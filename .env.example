# Upstash Redis (from Vercel Marketplace integration)
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Cron job protection – Vercel sets this automatically on cron requests
CRON_SECRET=your-cron-secret

# Vercel AI SDK provider — format: "<provider>:<model-id>"
# Supported providers: openai (add more in src/lib/ai-provider.ts)
AI_MODEL=openai:gpt-4o-mini

# API key for the chosen provider
OPENAI_API_KEY=sk-...

# The system prompt sent to the LLM when generating a daily prompt.
# Override this to change the theme/style without touching code.
AI_SYSTEM_PROMPT=You are a creative writing coach. Generate a single, thought-provoking creative writing prompt in one or two sentences. Return only the prompt text, nothing else.


---
import backgroundImage from '../assets/image.jpg';
import { Image } from 'astro:assets';
import '../styles/global.css';

type Props = {
	title?: string;
};
const { title = 'prompt.me' } = Astro.props as Props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="bg-wrapper">
			<Image src={backgroundImage} alt="" class="bg-image" priority={true} />
			<div class="bg-overlay"></div>
		</div>
		<slot />
	</body>
</html>


<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
	body {
		position: relative;
		background-color: #f5f5f5;
		overflow-x: hidden;
	}
	.bg-wrapper {
		position: fixed;
		inset: 0;
		z-index: 0;
		overflow: hidden;
	}
	.bg-image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top center;
	}
	.bg-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to bottom, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.15) 55%, rgba(255, 255, 255, 0.85) 100%);
		pointer-events: none;
	}
</style>

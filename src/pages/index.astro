---
import Layout from '../layouts/Layout.astro';
import PromptCard from '../components/PromptCard.astro';

const backendUrl = import.meta.env.BACKEND_URL;
const backendApiKey = import.meta.env.BACKEND_API_KEY;
let prompt = 'Could not load today\'s prompt. Please try again later.';
let dateLabel = '';

try {
  const res = await fetch(`${backendUrl}/prompt`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': backendApiKey,
    },
    body: JSON.stringify({ query: '{ scenario }' }),
  });
  if (res.ok) {
    const { data } = await res.json();
    if (data?.scenario) prompt = data.scenario;
  }
} catch (e) {
  // silently fall back to the default message above
}

if (!dateLabel) {
  dateLabel = new Date().toLocaleDateString('en-US', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).replace(/\//g, '.');
}
---

<Layout title="Prompt of the Day — prompt.me">
  <main class="relative z-10 flex min-h-screen flex-col items-center justify-start px-6 pt-16 pb-10 text-white sm:justify-center sm:pt-10 sm:px-8">
    <header class="mb-10 text-center sm:mb-16">
      <p class="date-label mb-3 text-[0.6rem] font-black uppercase tracking-[0.5em] text-white/50 opacity-70">{dateLabel}</p>
      <h1 class="title text-balance text-[clamp(2.2rem,7vw,5rem)] font-black uppercase leading-[0.85] tracking-[-0.04em] text-white">Prompt<br/>of the<br/>Day</h1>
    </header>

    <PromptCard prompt={prompt} variant="glow" />
  </main>
</Layout>

<style>
  .title {
    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "Arial Black", "Impact", Arial, sans-serif;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    font-stretch: condensed;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    font-weight: 900;
  }

  .date-label {
    font-family: "Courier New", "Courier", monospace;
    letter-spacing: 0.5em;
    font-weight: 900;
  }
</style>
